<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme is a thin shell: all real theming is done in Compose
         (ui/theme/Theme.kt). -->
    <style name="Theme.KitWallet" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.KitWallet.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/kit_navy</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.KitWallet</item>
    </style>

    <!-- Invisible, no-history relay used only to validate an Android text share and immediately
         hand it to MainActivity through process memory. -->
    <style name="Theme.KitWallet.ShareRelay" parent="android:style/Theme.NoDisplay" />
</resources>
